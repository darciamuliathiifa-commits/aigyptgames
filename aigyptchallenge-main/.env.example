# Frontend-safe Supabase values
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Backend-only secret. NEVER prefix this with VITE_ or NEXT_PUBLIC_.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SECRET_OR_SERVICE_ROLE_KEY

# Admin dashboard credentials used by the existing backend
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_TO_A_LONG_RANDOM_PASSWORD
ADMIN_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET
